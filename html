        function exportNotes() {
            const notes = document.getElementById('student-notes').value;
            if (!notes.trim()) {
                alert('No notes to export!');
                return;
            }
            
            // Create a downloadable text file
            const blob = new Blob([notes], { type: 'text/plain' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = 'lesson-notes.txt';
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            window.URL.revokeObjectURL(url);
        }

        // Load saved notes when page loads
        window.addEventListener('load', function() {
            const savedNotes = localStorage.getItem('studentNotes');
            if (savedNotes) {
                document.getElementById('student-notes').value = savedNotes;
            }

            // Safeguard: ensure at least one page/tab is active to avoid blank render on some hosts
            if (!document.querySelector('.page.active')) {
                const loginPage = document.getElementById('page-login');
                if (loginPage) {
                    loginPage.classList.add('active');
                }
            }

            if (typeof updateNavigationVisibility === 'function') {
                updateNavigationVisibility();
            }
        });

        // Clock Logic
        function updateClock() {
            const now = new Date();
            let h = now.getHours();
            let m = now.getMinutes();
            let ampm = h >= 12 ? 'PM' : 'AM';
            h = h % 12 || 12;
            m = m < 10 ? '0' + m : m;
            document.getElementById('clock').innerText = h + ":" + m + " " + ampm;
        }
        setInterval(updateClock, 1000);
        updateClock();
    </script>
</body>
</html>
